# ================================================
# ByggSjekk / nops.no – Miljøvariabler
# Kopier til .env og fyll inn verdier
# ALDRI legg .env under versjonskontroll.
# ================================================

# ── Applikasjon ──────────────────────────────────
APP_NAME=ByggSjekk
DEBUG=false
ENVIRONMENT=production

# ── Database (PostgreSQL) ─────────────────────────
DATABASE_URL=postgresql+asyncpg://byggsjekk:BYTT_MEG@db:5432/byggsjekk

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Sikkerhet ─────────────────────────────────────
# Generer med: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BYTT_MEG_MED_TILFELDIG_NOKKEL
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── MinIO / S3 ────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=BYTT_MEG
MINIO_SECRET_KEY=BYTT_MEG
MINIO_BUCKET=byggsjekk
MINIO_USE_SSL=false

# ── AI / LLM ──────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Render-generering ────────────────────────────
# fal.ai (primær): Registrer på fal.ai → Dashboard → Keys
FAL_KEY=
# Replicate (backup): replicate.com → API tokens
REPLICATE_API_KEY=

# ── Geodata / DOK-analyse (Geodata AS) ───────────
GEODATA_TOKEN=

# ── Arealplaner.no (Norkart) ──────────────────────
AREALPLANER_API_KEY=
AREALPLANER_BASE_URL=https://www.arealplaner.no/api

# ── Stripe ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# ── E-post (SMTP via Resend) ─────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_...
EMAIL_FROM=hey@nops.no
EMAIL_FROM_NAME=nops.no

# ── Frontend (Next.js) ────────────────────────────
NEXT_PUBLIC_API_URL=https://nops.no
CORS_ORIGINS=["https://nops.no"]

# ── pgAdmin (kun utvikling) ───────────────────────
PGADMIN_DEFAULT_EMAIL=admin@byggsjekk.no
PGADMIN_DEFAULT_PASSWORD=admin

# ── nops.no ───────────────────────────────────────
NOPS_BASE_URL=https://nops.no
